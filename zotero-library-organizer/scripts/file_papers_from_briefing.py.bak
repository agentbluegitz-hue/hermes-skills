#!/usr/bin/env python3
"""
File Arxiv papers from the daily AI briefing into Zotero library
"""

import json
import re
import sys
from datetime import datetime
from pyzotero import zotero
from hermes_tools import read_file

def load_config():
    """Load Zotero credentials from Hermes config"""
    try:
        # Try to load from .hermes/config.yaml or environment
        import os
        from pathlib import Path
        
        # Check for MCP config first
        config_path = "/home/agent-blue/.config/zotero-mcp/config.json"
        if os.path.exists(config_path):
            with open(config_path, 'r') as f:
                config = json.load(f)
            client_env = config.get('client_env', {})
            return {
                'ZOTERO_API_KEY': client_env.get('ZOTERO_API_KEY'),
                'ZOTERO_LIBRARY_ID': client_env.get('ZOTERO_LIBRARY_ID'),
                'ZOTERO_LIBRARY_TYPE': client_env.get('ZOTERO_LIBRARY_TYPE', 'user')
            }
        
        # Fallback to environment variables
        return {
            'ZOTERO_API_KEY': os.environ.get('ZOTERO_API_KEY'),
            'ZOTERO_LIBRARY_ID': os.environ.get('ZOTERO_LIBRARY_ID'),
            'ZOTERO_LIBRARY_TYPE': os.environ.get('ZOTERO_LIBRARY_TYPE', 'user')
        }
    except Exception as e:
        print(f"Error loading Zotero configuration: {e}")
        return None

def init_zotero(config):
    """Initialize Zotero API connection"""
    try:
        zot = zotero.Zotero(
            config['ZOTERO_LIBRARY_ID'],
            config['ZOTERO_LIBRARY_TYPE'],
            config['ZOTERO_API_KEY']
        )
        # Test connection
        zot.items(limit=1)
        return zot
    except Exception as e:
        print(f"Failed to initialize Zotero API: {e}")
        return None

def extract_arxiv_ids_from_briefing(briefing_path):
    """Extract Arxiv IDs from the briefing file"""
    try:
        result = read_file(path=briefing_path)
        if result.get('error'):
            print(f"Error reading briefing file: {result['error']}")
            return []
        
        content = result['content']
        # Extract Arxiv URLs
        arxiv_pattern = r'https://arxiv\.org/(?:abs|html)/(\d+\.\d+(?:v\d+)?)'
        matches = re.findall(arxiv_pattern, content)
        return list(set(matches))  # Remove duplicates
    except Exception as e:
        print(f"Error extracting Arxiv IDs from briefing: {e}")
        return []

def get_paper_metadata(arxiv_id):
    """Get metadata for an Arxiv paper"""
    import urllib.request
    import xml.etree.ElementTree as ET
    
    try:
        # Use Arxiv API to get paper metadata
        url = f"http://export.arxiv.org/api/query?id_list={arxiv_id}"
        with urllib.request.urlopen(url) as response:
            xml_data = response.read()
        
        root = ET.fromstring(xml_data)
        # Define namespace
        ns = {'atom': 'http://www.w3.org/2005/Atom'}
        
        entry = root.find('atom:entry', ns)
        if entry is None:
            return None
        
        title_elem = entry.find('atom:title', ns)
        title = title_elem.text.strip() if title_elem is not None else "Unknown Title"
        
        # Clean up title (remove extra whitespace/newlines)
        title = re.sub(r'\s+', ' ', title)
        
        return {
            'id': arxiv_id,
            'title': title,
            'url': f'https://arxiv.org/abs/{arxiv_id}'
        }
    except Exception as e:
        print(f"Error fetching metadata for Arxiv:{arxiv_id}: {e}")
        return None

def file_arxiv_paper(zot, arxiv_id, title, tags=None):
    """File an Arxiv paper by ID into Zotero"""
    if tags is None:
        tags = []
    
    # Add standard tags for AI agent papers
    if 'agent' in title.lower() or 'agents' in title.lower():
        tags.append('AI Agents')
    if 'llm' in title.lower():
        tags.append('LLM')
    if 'multi' in title.lower() or 'agent' in title.lower():
        tags.append('Multi-Agent Systems')
    
    # Prepare item data
    item_data = {
        'itemType': 'blogPost',  # Using blogPost as Arxiv doesn't have exact match
        'title': title,
        'url': f'https://arxiv.org/abs/{arxiv_id}',
        'accessDate': datetime.now().strftime('%Y-%m-%d'),
        'tags': [{'tag': tag} for tag in tags]
    }
    
    try:
        # Check if item already exists by URL
        existing = zot.items(q=title[:50])  # Search by partial title
        existing_urls = [item.get('data', {}).get('url', '') for item in existing]
        
        if f'https://arxiv.org/abs/{arxiv_id}' not in existing_urls:
            # Create new item
            response = zot.create_items([item_data])
            if response['success']:
                print(f"✓ Successfully filed: {title} (Arxiv:{arxiv_id})")
                return True
            else:
                print(f"✗ Failed to file {title}: {response}")
                return False
        else:
            print(f"○ Skipped (already exists): {title} (Arxiv:{arxiv_id})")
            return True
    except Exception as e:
        print(f"✗ Error filing {title}: {e}")
        return False

def main():
    """Main function to file Arxiv papers from briefing"""
    print("=== Filing Arxiv Papers from AI Briefing to Zotero ===")
    
    # Find the most recent briefing file
    import glob
    import os
    
    briefing_files = []
    briefing_files.extend(glob.glob('/tmp/ai_briefing_*.md'))
    briefing_files.extend(glob.glob('/home/agent-blue/ai_briefing_*.md'))
    
    if not briefing_files:
        print("ERROR: No briefing files found")
        return 1
    
    # Get the most recent file
    latest_briefing = max(briefing_files, key=os.path.getctime)
    print(f"Processing briefing: {latest_briefing}")
    
    # Load configuration
    config = load_config()
    if not config:
        print("ERROR: Could not load Zotero configuration")
        return 1
    
    # Initialize Zotero
    zot = init_zotero(config)
    if not zot:
        print("ERROR: Could not initialize Zotero connection")
        return 1
    
    print(f"Connected to Zotero library {config['ZOTERO_LIBRARY_ID']}")
    
    # Extract Arxiv IDs from briefing
    arxiv_ids = extract_arxiv_ids_from_briefing(latest_briefing)
    if not arxiv_ids:
        print("No Arxiv IDs found in briefing")
        return 0
    
    print(f"Found {len(arxiv_ids)} unique Arxiv IDs in briefing: {arxiv_ids}")
    
    # Process each paper
    success_count = 0
    for arxiv_id in arxiv_ids:
        print(f"\nProcessing Arxiv:{arxiv_id}")
        
        # Get paper metadata
        metadata = get_paper_metadata(arxiv_id)
        if not metadata:
            print(f"✗ Could not get metadata for Arxiv:{arxiv_id}")
            continue
        
        # File the paper
        if file_arxiv_paper(zot, metadata['id'], metadata['title']):
            success_count += 1
    
    print(f"\n=== Summary ===")
    print(f"Successfully filed: {success_count}/{len(arxiv_ids)} papers")
    
    if success_count == len(arxiv_ids):
        print("All papers filed successfully! 🎉")
        return 0
    else:
        print("Some papers failed to file. Check errors above.")
        return 1

if __name__ == "__main__":
    sys.exit(main())